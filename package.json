{
  "name": "multi-user-browser-v2",
  "version": "1.0.0",
  "description": "多用户并发管理浏览器 v2 - 基于 Electron BrowserView",
  "main": "src/main/index.js",
  "author": "mmmmh2o <mmmmh2o@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmmmh2o/multi-user-browser-v2.git"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "build:dir": "vite build && electron-builder --dir",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,less}\"",
    "test": "jest",
    "start": "electron .",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "electron-store": "^8.0.0",
    "electron-log": "^5.0.0",
    "electron-updater": "^6.0.0",
    "uuid": "^9.0.0",
    "fs-extra": "^11.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "@reduxjs/toolkit": "^2.0.0",
    "react-redux": "^9.0.0",
    "antd": "^5.0.0",
    "@ant-design/icons": "^5.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jest": "^29.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "prettier": "^3.0.0",
    "less": "^4.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
